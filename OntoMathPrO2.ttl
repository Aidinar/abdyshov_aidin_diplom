mathematics:E2934 rdf:type owl:Class ;
                  rdfs:subClassOf mathematics:E2931 ;
                  rdfs:comment "Последовательность, элементы которой не подчиняются никакому отношению порядка или закономерности." ;
                  rdfs:label "Неупорядоченная последовательность"@ru .


