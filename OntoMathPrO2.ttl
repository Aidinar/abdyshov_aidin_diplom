@prefix : <http://www.w3.org/2002/07/owl#> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix xsp: <http://www.owl-ontologies.com/2005/08/07/xsp.owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix swrl: <http://www.w3.org/2003/11/swrl#> .
@prefix swrlb: <http://www.w3.org/2003/11/swrlb#> .
@prefix protege: <http://protege.stanford.edu/plugins/owl/protege#> .
@prefix mathematics: <http://cll.niimm.ksu.ru/ontologies/mathematics#> .
@base <http://www.w3.org/2002/07/owl#> .

<http://cll.niimm.ksu.ru/ontologies/mathematics#> rdf:type owl:Ontology ;
                                                   dc:creator "Alik Kirillovich <alik.kirillovich@gmail.com>" ,
                                                              "Anna Kayumova <annakayu@gmail.com>" ,
                                                              "Elena Utkina <eutkina1@yandex.ru>" ,
                                                              "Evgeny Lipachev <elipachev@gmail.com>" ,
                                                              "Ilgiz Kayumov <ikayumov@gmail.com>" ,
                                                              "Marjan Matvejchuk <marjan.matvejchuk@ksu.ru>" ,
                                                              "Nikita Zhiltsov <nikita.zhiltsov@gmail.com>" ,
                                                              "Olga Nevzorova <onevzoro@gmail.com>" ,
                                                              "Pyotr Ivanshin <pivanshin@gmail.com>" ,
                                                              "Valery Solovyev <maki.solovyev@mail.ru>" ;
                                                   dc:title "OntoMath Pro" ;
                                                   rdfs:comment "The ontology describes mathematical entities as well as mathematical theories, and relations between them."@en ,
                                                                "Онтология описывает разделы математики, элементы математического знания и отношения между ними."@ru ;
                                                   owl:versionInfo "1.12.6" .

#################################################################
#    Annotation properties
#################################################################

###  http://cll.niimm.ksu.ru/ontologies/mathematics#disjointWith
mathematics:disjointWith rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/creator
dc:creator rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/title
dc:title rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2000/01/rdf-schema#comment
rdfs:comment rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2000/01/rdf-schema#label
rdfs:label rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2002/07/owl#deprecated
owl:deprecated rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2002/07/owl#versionInfo
owl:versionInfo rdf:type owl:AnnotationProperty .


#################################################################
#    Datatypes
#################################################################

###  http://www.w3.org/1999/02/22-rdf-syntax-ns#PlainLiteral
rdf:PlainLiteral rdf:type rdfs:Datatype .


###  http://www.w3.org/2001/XMLSchema#string
xsd:string rdf:type rdfs:Datatype .


#################################################################
#    Object Properties
#################################################################

###  http://cll.niimm.ksu.ru/ontologies/mathematics#P1
mathematics:P1 rdf:type owl:ObjectProperty ;
               owl:inverseOf mathematics:P2 ;
               rdfs:label "defines"@en ,
                          "определяет"@ru .


###  http://cll.niimm.ksu.ru/ontologies/mathematics#P2
mathematics:P2 rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf owl:topObjectProperty ;
               rdfs:domain mathematics:E34 ;
               rdfs:range mathematics:E34 ;
               rdfs:comment "Свойство указывает на то, что второй элемент используется при определении первого, но при этом свойства ISA (\"Подкласс - класс\") между ними нет."@ru ;
               rdfs:label "is defined by"@en ,
                          "определяется через"@ru .


###  http://cll.niimm.ksu.ru/ontologies/mathematics#P3
mathematics:P3 rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf owl:topObjectProperty ;
               owl:inverseOf mathematics:P4 ;
               rdfs:domain mathematics:E34 ;
               rdfs:range mathematics:E1 ;
               rdfs:comment "Свойство указывает на принадлежность данного элемента математического знания данному разделу математики."@ru ;
               rdfs:label "belongs to"@en ,
                          "относится к"@ru .


###  http://cll.niimm.ksu.ru/ontologies/mathematics#P4
mathematics:P4 rdf:type owl:ObjectProperty ;
               rdfs:label "contains"@en ,
                          "содержит"@ru .


###  http://cll.niimm.ksu.ru/ontologies/mathematics#P5
mathematics:P5 rdf:type owl:ObjectProperty ,
                        owl:SymmetricProperty ,
                        owl:TransitiveProperty ;
               rdfs:domain mathematics:E34 ;
               rdfs:range mathematics:E34 ;
               rdfs:comment "Свойство устанавливает отношение между близкими терминами."@ru ;
               rdfs:label "see also"@en ,
                          "смотри также"@ru .


###  http://cll.niimm.ksu.ru/ontologies/mathematics#P6
mathematics:P6 rdf:type owl:ObjectProperty ;
               owl:inverseOf mathematics:P7 ;
               rdfs:label "solves"@en ,
                          "решает"@ru .


###  http://cll.niimm.ksu.ru/ontologies/mathematics#P7
mathematics:P7 rdf:type owl:ObjectProperty ;
               rdfs:domain mathematics:E339 ;
               rdfs:range mathematics:E449 ;
               rdfs:label "is solved by"@en ,
                          "решается с помощью"@ru .


###  http://www.w3.org/2002/07/owl#topObjectProperty
owl:topObjectProperty rdf:type owl:ObjectProperty .


#################################################################
#    Classes
#################################################################

###  http://cll.niimm.ksu.ru/ontologies/mathematics#E1
mathematics:E1 rdf:type owl:Class ;
               rdfs:comment "Верхний уровень иерархии разделов математики"@ru ;
               rdfs:label "Field of mathematics"@en ,
                          "раздел математики"@ru .


###  http://cll.niimm.ksu.ru/ontologies/mathematics#E10
mathematics:E10 rdf:type owl:Class ;
                rdfs:subClassOf mathematics:E8 ;
                rdfs:comment "http://dic.academic.ru/dic.nsf/enc_mathematics/2413/%D0%9A%D0%9E%D0%9D%D0%A4%D0%9E%D0%A0%D0%9C%D0%9D%D0%9E" ;
                rdfs:label " Conformly differential geometry "@en ,
                           "Конформно-дифференциальная геометрия"@ru .


###  http://cll.niimm.ksu.ru/ontologies/mathematics#E100
mathematics:E100 rdf:type owl:Class ;
                 rdfs:subClassOf mathematics:E86 ,
                                 mathematics:E938 ;
                 rdfs:comment "http://en.wikipedia.org/wiki/Envelope_%28mathematics%29"@en ;
                 rdfs:label "Envelope "@en ,
                            "огибающая"@ru .


###  http://cll.niimm.ksu.ru/ontologies/mathematics#E1000
mathematics:E1000 rdf:type owl:Class ;
                  rdfs:subClassOf mathematics:E982 ;
                  rdfs:comment "http://en.wikipedia.org/wiki/One-parameter_group"@ru ;
                  rdfs:label "One-parameter subgroup of Lie group"@en ,
                             "однопараметрическая подгруппа группы Ли"@ru .


###  http://cll.niimm.ksu.ru/ontologies/mathematics#E1001
mathematics:E1001 rdf:type owl:Class ;
                  owl:equivalentClass [ rdf:type owl:Restriction ;
                                        owl:onProperty mathematics:P3 ;
                                        owl:allValuesFrom mathematics:E5
                                      ] ;
                  rdfs:subClassOf mathematics:E982 ;
                  rdfs:comment "http://www.mathnet.ru/php/archive.phtml?wshow=paper&jrnid=kutgs&paperid=242&option_lang=rus"@ru ;
                  rdfs:label "One-term Lie group"@en ,
                             "одночленная группа Ли"@ru .


###  http://cll.niimm.ksu.ru/ontologies/mathematics#E1002
mathematics:E1002 rdf:type owl:Class ;
                  rdfs:subClassOf mathematics:E982 ;
                  rdfs:comment "http://en.wikipedia.org/wiki/Semisimple_group"@en ;
                  rdfs:label "Semisimple group"@en ,
                             "полупростая группа"@ru .


###  http://cll.niimm.ksu.ru/ontologies/mathematics#E1003
mathematics:E1003 rdf:type owl:Class ;
                  rdfs:subClassOf mathematics:E1002 ;
                  rdfs:comment "полупростая группа Ли, являющаяся компактной"@ru ;
                  rdfs:label "Room semisimple Lie group"@en ,
                             "компактная полупростая группа Ли"@ru .


###  http://cll.niimm.ksu.ru/ontologies/mathematics#E1004
mathematics:E1004 rdf:type owl:Class ;
                  rdfs:subClassOf mathematics:E982 ;
                  rdfs:comment "http://en.wikipedia.org/wiki/Simple_group"@en ;
                  rdfs:label "Simple group"@en ,
                             "простая группа"@ru .


###  http://cll.niimm.ksu.ru/ontologies/mathematics#E1005
mathematics:E1005 rdf:type owl:Class ;
                  rdfs:subClassOf mathematics:E982 ;
                  rdfs:comment "http://en.wikipedia.org/wiki/Lie_group#The_exponential_map"@en ;
                  rdfs:label "Regular subgroup of Lie group"@en ,
                             "регулярная подгруппа группы Ли"@ru .


###  http://cll.niimm.ksu.ru/ontologies/mathematics#E1006
mathematics:E1006 rdf:type owl:Class ;
                  rdfs:subClassOf mathematics:E982 ;
                  rdfs:comment "http://en.wikipedia.org/wiki/Connected_component_of_the_identity"@en ;
                  rdfs:label "Connected component of the identity"@en ,
                             "связная компонента единицы"@ru .


###  http://cll.niimm.ksu.ru/ontologies/mathematics#E1007
mathematics:E1007 rdf:type owl:Class ;
                  owl:equivalentClass [ rdf:type owl:Restriction ;
                                        owl:onProperty mathematics:P3 ;
                                        owl:allValuesFrom mathematics:E28
                                      ] ;
                  rdfs:subClassOf mathematics:E982 ;
                  rdfs:comment "http://en.wikipedia.org/wiki/Group_center"@en ;
                  rdfs:label "Lie group center"@en ,
