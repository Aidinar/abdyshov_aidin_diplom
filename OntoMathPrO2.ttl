###  http://cll.niimm.ksu.ru/ontologies/mathematics#E1018
mathematics:E1018 rdf:type owl:Class ;
                  rdfs:subClassOf mathematics:E980 ;
                  rdfs:comment "http://en.wikipedia.org/wiki/Almost_complex_manifold"@en ;
                  rdfs:label "Almost complex manifold"@en ,
                             "почти комлексное многообразие"@ru .


###  http://cll.niimm.ksu.ru/ontologies/mathematics#E1019
mathematics:E1019 rdf:type owl:Class ;
                  rdfs:subClassOf mathematics:E1018 ,
                                  mathematics:E980 ;
                  rdfs:comment "http://en.wikipedia.org/wiki/Complex_manifold"@en ;
                  rdfs:label "Complex manifold"@en ,
                             "комплексное многообразие"@ru .


###  http://cll.niimm.ksu.ru/ontologies/mathematics#E102
mathematics:E102 rdf:type owl:Class ;
                 rdfs:subClassOf mathematics:E101 ;
                 rdfs:comment "http://ru.wikipedia.org/wiki/%D0%9A%D0%BE%D0%BD%D0%B8%D1%87%D0%B5%D1%81%D0%BA%D0%BE%D0%B5_%D1%81%D0%B5%D1%87%D0%B5%D0%BD%D0%B8%D0%B5" ;
                 rdfs:label "Conic section"@en ,
                            "коническое сечение"@ru .


