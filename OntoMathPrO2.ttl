###  http://cll.niimm.ksu.ru/ontologies/mathematics#E1016
mathematics:E1016 rdf:type owl:Class ;
                  rdfs:subClassOf mathematics:E980 ;
                  rdfs:comment "Сабинин Л.В. Методы неассоциативной алгебры в дифференциальной геометрии. (Кобаяси Ш., Номидзу К. Основы дифференцальной геометрии.)"@ru ;
                  rdfs:label "Modulus"@en ,
