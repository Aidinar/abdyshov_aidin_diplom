mathematics:E1025 rdf:type owl:Class ;
                  rdfs:subClassOf mathematics:E1022 ,
                                  mathematics:E1113 ;
                  rdfs:comment "http://en.wikipedia.org/wiki/Non-positive_curvature"@en ;
                  rdfs:label "Variety nonpositive curvature"@en ,
                             "многообразие неположительной кривизны"@ru .


