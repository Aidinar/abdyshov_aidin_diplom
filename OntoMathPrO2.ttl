                  rdfs:comment "http://ru.wikipedia.org/wiki/%D0%9F%D0%BE%D1%81%D0%BB%D0%B5%D0%B4%D0%BE%D0%B2%D0%B0%D1%82%D0%B5%D0%BB%D1%8C%D0%BD%D0%BE%D1%81%D1%82%D1%8C"@ru ;
                  rdfs:label "Последовательность"@ru .


###  http://cll.niimm.ksu.ru/ontologies/mathematics#E2932
mathematics:E2932 rdf:type owl:Class ;
                  rdfs:subClassOf mathematics:E2931 ;
                  rdfs:comment "Последовательность, не являющаяся монотонной."@ru ;
                  rdfs:label "Немонотонная последовательность"@ru .


###  http://cll.niimm.ksu.ru/ontologies/mathematics#E2933
mathematics:E2933 rdf:type owl:Class ;
                  rdfs:subClassOf mathematics:E2931 ;
                  rdfs:comment """Это последовательность, для которой не существует числа М>0 и номера N таких, что $|x_n|<=M$ для любого $n>N$.
Никольский С.М. Курс математического анализа. Т.1. М.: - Наука, 1975."""@ru ;
                  rdfs:label "Неограниченная последовательность"@ru .


