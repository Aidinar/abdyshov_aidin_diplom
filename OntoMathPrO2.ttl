###  http://cll.niimm.ksu.ru/ontologies/mathematics#E2999
mathematics:E2999 rdf:type owl:Class ;
                  rdfs:subClassOf mathematics:E2997 ;
                  rdfs:comment """Признак Абеля дает достаточные условия условной сходимости числового ряда. 
Числовой ряд $\\sum_0^\\infty{a_nb_n}$ сходится, если выполнены следующие условия:
 1.Последовательность $a_n$ монотонна и ограничена.
 2.Числовой ряд $\\sum_0^\\infty{b_n}$ сходится.
"""@ru ;
                  rdfs:label "Признак Абеля сходимости ряда"@ru .


