                                        owl:onProperty mathematics:P3 ;
                                        owl:allValuesFrom mathematics:E8
                                      ] ;
                  rdfs:subClassOf mathematics:E123 ;
                  rdfs:comment """A Poisson structure on $M$ is a bilinear map
 $$\\{.,.\\}:C^\\infty(M)xC^\\infty(M) \\to C^\\infty(M)$$
with the following properties:
1.  It is skew symmetric: $\\{f,g\\} = −\\{g,f\\}$.
2.  It obeys the Jacobi identity:$ \\{f,\\{g,h\\}\\} + \\{g,\\{h,f\\}\\} +\\ {h,\\{f,g\\}\\} = 0$.
3.  It is a derivation of $C^\\infty(M)$ in its first argument: $\\{fg,h\\} = f{g,h} + g\\{f,h\\}$.
"""@en ;
                  rdfs:label "Poisson structure"@en ,
                             "Пуассонова структура"@ru .


