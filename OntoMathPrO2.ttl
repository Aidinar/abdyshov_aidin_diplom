###  http://cll.niimm.ksu.ru/ontologies/mathematics#E293
mathematics:E293 rdf:type owl:Class ;
                 rdfs:subClassOf mathematics:E35 ,
                                 mathematics:E847 ;
                 rdfs:comment """В геометрии, топологии и близких разделах математики то́чкой называют абстрактный объект в пространстве, не имеющий ни объёма, ни площади, ни длины, ни каких-либо других измеримых характеристик. Таким образом, точкой называют нульмерный объект. Точка является одним из фундаментальных понятий в математике; любая геометрическая фигура считается состоящей из точек.
http://ru.wikipedia.org/wiki/%D0%A2%D0%BE%D1%87%D0%BA%D0%B0_(%D0%B3%D0%B5%D0%BE%D0%BC%D0%B5%D1%82%D1%80%D0%B8%D1%8F)"""@ru ;
                 rdfs:label "Point"@en ,
                            "точка"@ru .


###  http://cll.niimm.ksu.ru/ontologies/mathematics#E2930
mathematics:E2930 rdf:type owl:Class ;
                  owl:equivalentClass [ rdf:type owl:Restriction ;
                                        owl:onProperty mathematics:P3 ;
                                        owl:allValuesFrom mathematics:E23
                                      ] ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty mathematics:P5 ;
                                        owl:allValuesFrom mathematics:E1515
                                      ] ;
                  rdfs:subClassOf mathematics:E2929 ;
                  rdfs:comment "Голузин Г.М. Геометрическая теория функций комплексного переменного. - М: Наука. 1966."@ru ;
                  rdfs:label "Порядок целой функции"@ru .


