                  rdfs:label "непрерывное вейвлет-преобразование"@ru .


###  http://cll.niimm.ksu.ru/ontologies/mathematics#E2961
mathematics:E2961 rdf:type owl:Class ;
                  owl:equivalentClass [ rdf:type owl:Restriction ;
                                        owl:onProperty mathematics:P3 ;
                                        owl:allValuesFrom mathematics:E23
                                      ] ;
                  rdfs:subClassOf mathematics:E2957 ;
                  rdfs:comment """http://ru.wikipedia.org/wiki/%D0%9F%D1%80%D0%B5%D0%BE%D0%B1%D1%80%D0%B0%D0%B7%D0%BE%D0%B2%D0%B0%D0%BD%D0%B8%D0%B5_%D0%9C%D1%91%D0%B1%D0%B8%D1%83%D1%81%D0%B0

"""@ru ;
                  rdfs:label "Mobius transformation"@en ,
                             "Преобразование Мёбиуса"@ru ,
                             "дробно-линейное преобразование"@ru .


###  http://cll.niimm.ksu.ru/ontologies/mathematics#E2962
mathematics:E2962 rdf:type owl:Class ;
                  owl:equivalentClass [ rdf:type owl:Restriction ;
                                        owl:onProperty mathematics:P3 ;
                                        owl:allValuesFrom mathematics:E23
                                      ] ;
                  rdfs:subClassOf mathematics:E2957 ;
                  rdfs:comment """Инверсия (от лат. inversio — обращение) относительно окружности есть преобразование евклидовой плоскости, переводящее обобщённые окружности (окружности либо прямые) в обобщённые окружности, при котором одна из окружностей поточечно переводится в себя.
http://ru.wikipedia.org/wiki/%D0%98%D0%BD%D0%B2%D0%B5%D1%80%D1%81%D0%B8%D1%8F_(%D0%B3%D0%B5%D0%BE%D0%BC%D0%B5%D1%82%D1%80%D0%B8%D1%8F)"""@ru ;
                  rdfs:label "Inversion"@en ,
                             "инверсия"@ru .


###  http://cll.niimm.ksu.ru/ontologies/mathematics#E2963
mathematics:E2963 rdf:type owl:Class ;
                  owl:equivalentClass [ rdf:type owl:Restriction ;
                                        owl:onProperty mathematics:P3 ;
                                        owl:allValuesFrom mathematics:E23
                                      ] ;
                  rdfs:subClassOf mathematics:E2957 ;
                  rdfs:comment "Голузин Г.М. Геометрическая теория функций комплексного переменного. - М: Наука. 1966."@ru ;
                  rdfs:label "Conformal mapping"@en ,
                             "конформное преобразование"@ru .


###  http://cll.niimm.ksu.ru/ontologies/mathematics#E2964
mathematics:E2964 rdf:type owl:Class ;
                  rdfs:subClassOf mathematics:E2957 ;
                  rdfs:comment """Линейное преобразование на плоскости – это такое точечное отображение плоскости в себя, при котором любая прямая переходит в прямую. Произвольная точка с координатами (X,Y) в результате линейного преобразования переходит в свой образ - в точку с ко­ординатами (X1,Y1) согласно формулам 
$X1 = A*X+B*Y+C,  Y1 = D*X+E*Y+F, $
где A,B,C,D,E,F – числа, коэффициенты данного преобразова­ния, однозначно его определяющие. """@ru ;
                  rdfs:label "Linear operator"@en ,
                             "линейное преобразование"@ru .


###  http://cll.niimm.ksu.ru/ontologies/mathematics#E2965
mathematics:E2965 rdf:type owl:Class ;
                  rdfs:subClassOf mathematics:E2957 ;
                  rdfs:comment " Гельфанд И. М. Лекции по линейной алгебре. изд. МЦНМО, 1998."@ru ;
                  rdfs:label "Matrix transformation"@en ,
                             "матричное преобразование"@ru .


###  http://cll.niimm.ksu.ru/ontologies/mathematics#E2966
mathematics:E2966 rdf:type owl:Class ;
