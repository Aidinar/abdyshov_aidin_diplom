###  http://cll.niimm.ksu.ru/ontologies/mathematics#E2986
mathematics:E2986 rdf:type owl:Class ;
                  rdfs:subClassOf mathematics:E2985 ;
                  rdfs:comment """Признак Абеля дает достаточные условия равномерной сходимости функционального ряда. Функциональный ряд
$$
\\sum^\\infty_0{a_n(x)b_n(x)}
$$
сходится равномерно на множестве $E$, если выполнены следующие условия:
 1.Последовательность действительнозначных функций $a_n(x)$ равномерно ограничена на $E$ и монотонна.
 2.Функциональный ряд комплекснозначных функций $b_n(x)$ равномерно сходится на $E$.
"""@ru ;
                  rdfs:label "Признак Абеля"@ru .


