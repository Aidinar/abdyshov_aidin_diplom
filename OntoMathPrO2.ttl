###  http://cll.niimm.ksu.ru/ontologies/mathematics#E2020
mathematics:E2020 rdf:type owl:Class ;
                  owl:equivalentClass [ rdf:type owl:Restriction ;
                                        owl:onProperty mathematics:P5 ;
                                        owl:allValuesFrom mathematics:E1746
                                      ] ;
                  rdfs:subClassOf mathematics:E2008 ,
                                  mathematics:E3107 ;
                  rdfs:comment """Пусть  $\\Sigma$— кусочно-гладкая поверхность $(p=2)$ в трёхмерном евклидовом пространстве $(n=3)$, $F$  — дифференцируемое векторное поле. Тогда циркуляция векторного поля вдоль замкнутого контура $\\partia\\Sigma$ равна потоку ротора (вихря) поля через поверхность $\\Sigma$, ограниченную контуром:
 $$\\int_\\Sigma{rot F\\partial\\Sigma}=\\int_{\\partial\\Sigma}{FDr}."""@ru ;
                  rdfs:label "Stoke's formula"@en ,
                             "формула Стокса"@ru .


