mathematics:E1014 rdf:type owl:Class ;
                  rdfs:subClassOf mathematics:E980 ;
                  rdfs:comment "http://ru.wikipedia.org/wiki/%D0%94%D0%B8%D1%84%D1%84%D0%B5%D1%80%D0%B5%D0%BD%D1%86%D0%B8%D1%80%D1%83%D0%B5%D0%BC%D0%BE%D0%B5_%D0%BC%D0%BD%D0%BE%D0%B3%D0%BE%D0%BE%D0%B1%D1%80%D0%B0%D0%B7%D0%B8%D0%B5" ;
                  rdfs:label "многообразие класса $C(r)$"@ru .


###  http://cll.niimm.ksu.ru/ontologies/mathematics#E1015
mathematics:E1015 rdf:type owl:Class ;
                  rdfs:subClassOf mathematics:E980 ;
                  rdfs:comment "В.В.Вишневский, В.В. Шурыгин, А.П. Широков, Многообразия над алгебрами"@ru ;
                  rdfs:label "Varifold off algebra"@en ,
