http://ru.wikipedia.org/wiki/%D0%A4%D1%83%D0%BD%D0%BA%D1%86%D0%B8%D0%BE%D0%BD%D0%B0%D0%BB%D1%8C%D0%BD%D1%8B%D0%B9_%D1%80%D1%8F%D0%B4#.D0.9F.D1.80.D0.B8.D0.B7.D0.BD.D0.B0.D0.BA.D0.B8_.D1.80.D0.B0.D0.B2.D0.BD.D0.BE.D0.BC.D0.B5.D1.80.D0.BD.D0.BE.D0.B9_.D1.81.D1.85.D0.BE.D0.B4.D0.B8.D0.BC.D0.BE.D1.81.D1.82.D0.B8"""@ru ;
                  rdfs:label "Признак Вейерштрасса"@ru .


