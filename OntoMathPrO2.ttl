mathematics:E1020 rdf:type owl:Class ;
                  rdfs:subClassOf mathematics:E980 ;
                  rdfs:comment "http://en.wikipedia.org/wiki/Pseudo-Riemannian_manifold"@en ;
                  rdfs:label "Pseudo-Riemannian manifold"@en ,
                             "псевдориманово многообразие"@ru .


###  http://cll.niimm.ksu.ru/ontologies/mathematics#E1021
mathematics:E1021 rdf:type owl:Class ;
                  owl:equivalentClass [ rdf:type owl:Restriction ;
                                        owl:onProperty mathematics:P5 ;
                                        owl:allValuesFrom mathematics:E12
                                      ] ;
                  rdfs:subClassOf mathematics:E980 ;
                  rdfs:comment "http://en.wikipedia.org/wiki/Poisson_manifold"@en ;
                  rdfs:label "Poisson manifold"@en ,
                             "пуассоново многообразие"@ru .


###  http://cll.niimm.ksu.ru/ontologies/mathematics#E1022
mathematics:E1022 rdf:type owl:Class ;
                  rdfs:subClassOf mathematics:E980 ;
                  rdfs:comment "http://en.wikipedia.org/wiki/Riemannian_manifold"@en ;
                  rdfs:label "Riemannian manifold"@en ,
                             "риманово многообразие"@ru .


###  http://cll.niimm.ksu.ru/ontologies/mathematics#E1023
mathematics:E1023 rdf:type owl:Class ;
                  rdfs:subClassOf mathematics:E1022 ;
                  rdfs:comment "http://en.wikipedia.org/wiki/K%C3%A4hler_manifold"@en ;
                  rdfs:label "Kahler varifold"@en ,
                             "кэлерово многообразие"@ru .


###  http://cll.niimm.ksu.ru/ontologies/mathematics#E1024
mathematics:E1024 rdf:type owl:Class ;
                  owl:equivalentClass [ rdf:type owl:Restriction ;
                                        owl:onProperty mathematics:P3 ;
                                        owl:allValuesFrom mathematics:E13
                                      ] ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty mathematics:P5 ;
                                        owl:allValuesFrom mathematics:E1552
                                      ] ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty mathematics:P5 ;
                                        owl:allValuesFrom mathematics:E1727
                                      ] ;
                  rdfs:subClassOf mathematics:E1022 ;
                  rdfs:comment "http://en.wikipedia.org/wiki/Einstein_manifold"@en ;
                  rdfs:label "Einstein manifold"@en ,
                             "многообразие Эйнштейна"@ru .


