                  rdfs:subClassOf mathematics:E2991 ;
                  rdfs:comment """Признак Дирихле — теорема, указывающая достаточные условия сходимости несобственных интегралов и суммируемости бесконечных рядов. Названа в честь немецкого математика Лежёна-Дирихле.
http://ru.wikipedia.org/wiki/%D0%9F%D1%80%D0%B8%D0%B7%D0%BD%D0%B0%D0%BA_%D0%94%D0%B8%D1%80%D0%B8%D1%85%D0%BB%D0%B5"""@ru ;
                  rdfs:label "Признак Дирихле для интегралов"@ru .


