                  rdfs:subClassOf mathematics:E2990 ;
                  rdfs:comment "Это признаки сходимости, применяемые для исследования сходимости интегралов"@ru ;
                  rdfs:label "Признак сходимости интеграла"@ru .


###  http://cll.niimm.ksu.ru/ontologies/mathematics#E2992
mathematics:E2992 rdf:type owl:Class ;
                  rdfs:subClassOf mathematics:E2991 ;
                  rdfs:comment """Признак Абеля дает достаточные условия сходимости несобственного интеграла.
Пусть функции $f(x),g(x)$ и определены на промежутке $[a,\\infty)$. Тогда несобственный интеграл $\\int_a^\\infty{f(x)g(x)dx} сходится, если выполнены следующие условия:
 1.Функция $f(x)$ интегрируема на $[a,b],b>a$.
 2.Функция $g(x)$ ограничена и монотонна.
"""@ru ;
                  rdfs:label "Признак Абеля для интегралов"@ru .


