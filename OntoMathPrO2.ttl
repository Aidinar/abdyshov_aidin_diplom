###  http://cll.niimm.ksu.ru/ontologies/mathematics#E1032
mathematics:E1032 rdf:type owl:Class ;
                  owl:equivalentClass [ rdf:type owl:Restriction ;
                                        owl:onProperty mathematics:P3 ;
                                        owl:allValuesFrom mathematics:E14
                                      ] ,
