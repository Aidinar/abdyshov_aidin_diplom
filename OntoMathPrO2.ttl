###  http://cll.niimm.ksu.ru/ontologies/mathematics#E1008
mathematics:E1008 rdf:type owl:Class ;
                  rdfs:subClassOf mathematics:E980 ;
                  rdfs:comment "http://en.wikipedia.org/wiki/Differentiable_manifold"@en ;
                  rdfs:label "Differentiable manifold"@en ,
