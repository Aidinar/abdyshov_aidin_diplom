###  http://cll.niimm.ksu.ru/ontologies/mathematics#E1576
mathematics:E1576 rdf:type owl:Class ;
                  owl:equivalentClass [ rdf:type owl:Restriction ;
                                        owl:onProperty mathematics:P1 ;
                                        owl:allValuesFrom mathematics:E1032
                                      ] ;
                  rdfs:subClassOf mathematics:E1552 ;
                  rdfs:comment """Пусть  $M^n$ — $n$-мерное связное $C^\\infty$-многообразие. Обозначим через $TM^n$ касательное расслоение $M^n$. Тогда финслеровой метрикой на $M^n$ называется функция $F$, удовлетворяющая свойствам:
 1. $F\\in C^\\infty(TM^n\\\\{0\\})$;
 2. $F$ положительно однородна первой степени; 
3.Для любой пары $(x,y)\\in TM_n$ билинейная форма 
$$ g_y(u,v)=1/2 \\partial^2/(\\partial t\\patrial s) F[x,y+su+tv]|_{s=t=0)$$ 
положительно определена.
"""@ru ;
                  rdfs:label "Finsler metric"@en ,
                             "финслерова метрика"@ru .


###  http://cll.niimm.ksu.ru/ontologies/mathematics#E1577
mathematics:E1577 rdf:type owl:Class ;
                  rdfs:subClassOf mathematics:E1505 ;
                  rdfs:comment """Минорантой по отношению к данной функции на заданном множестве является функция, которая принимает на этом множестве значения меньшие, чем исходная функция.
Никольский С.М. Курс математического анализа. Т.1,2. М.: - Наука, 1975."""@ru ;
                  rdfs:label "Minorant"@en ,
                             "миноранта"@ru .


